{
  "family": "poc-agenda-dashboard-task-def",
  "containerDefinitions": [
    {
      "name": "dashboard-container",
      "image": "557643339346.dkr.ecr.us-east-1.amazonaws.com/poc-agenda-dashboard:latest",
      "cpu": 512,
      "memoryReservation": 450,
      "portMappings": [
        {
          "containerPort": 8082,
          "hostPort": 8082,
          "protocol": "tcp",
          "name": "dashboard-8082-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "KAFKA_SECURITY_PROTOCOL",
          "value": "SASL_SSL"
        },
        {
          "name": "KAFKA_TOPIC_DELETED",
          "value": ""
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/poc-agenda-dashboard",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": []
    }
  ],
  "executionRoleArn": "arn:aws:iam::557643339346:role/ecsTaskExecutionRole",
  "networkMode": "bridge",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "EC2"
  ],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}